{
  "manifest_version": 3,
  "name": "BestiaryArena SuperMod Loader",
  "version": "4.3.10",
  "description": "SuperMod loader for Bestiary Arena - Advanced mod management system with enhanced features and custom mods.",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.bestiaryarena.com/*",
        "*://bestiaryarena.com/*"
      ],
      "exclude_matches": [
        "*://bestiaryarena.com/abilities*",
        "*://*.bestiaryarena.com/abilities*",
        "*://bestiaryarena.com/profile*",
        "*://*.bestiaryarena.com/profile*",
        "*://bestiaryarena.com/recolor*",
        "*://*.bestiaryarena.com/recolor*",
        "*://bestiaryarena.com/assets*",
        "*://*.bestiaryarena.com/assets*",
        "*://bestiaryarena.com/_next/*",
        "*://*.bestiaryarena.com/_next/*",
        "*://bestiaryarena.com/seasons*",
        "*://*.bestiaryarena.com/seasons*"
      ],
      "js": [
        "content/extension-url.js",
        "content/injector.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.bestiaryarena.com/*",
        "*://bestiaryarena.com/*"
      ],
      "exclude_matches": [
        "*://bestiaryarena.com/abilities*",
        "*://*.bestiaryarena.com/abilities*",
        "*://bestiaryarena.com/profile*",
        "*://*.bestiaryarena.com/profile*",
        "*://bestiaryarena.com/recolor*",
        "*://*.bestiaryarena.com/recolor*",
        "*://bestiaryarena.com/assets*",
        "*://*.bestiaryarena.com/assets*",
        "*://bestiaryarena.com/_next/*",
        "*://*.bestiaryarena.com/_next/*",
        "*://bestiaryarena.com/seasons*",
        "*://*.bestiaryarena.com/seasons*"
      ],
      "js": [
        "content/extension-url.js",
        "content/utility_injector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "unlimitedStorage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.bestiaryarena.com/*",
    "*://bestiaryarena.com/*",
    "*://bestiary-arena-ranking.vercel.app/*",
    "https://vip-list-messages-default-rtdb.europe-west1.firebasedatabase.app/*"
  ],
  "optional_host_permissions": [
    "*://*.gist.githubusercontent.com/*",
    "*://gist.githubusercontent.com/*",
    "*://*.raw.githubusercontent.com/*",
    "*://raw.githubusercontent.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/extension-url.js",
        "content/platform.js",
        "content/client.js",
        "content/local_mods.js",
        "content/mod-registry.js",
        "content/mod-coordination.mjs",
        "content/utility_injector.js",
        "content/ba-sandbox-utils.mjs",
        "content/custom-battles.js",
        "assets/icons/*",
        "assets/depot/*",
        "assets/js/*",
        "assets/fonts/*",
        "assets/locales/*",
        "assets/equipment/*",
        "assets/guild/*",
        "assets/quests/*",
        "assets/skills/*",
        "mods/*",
        "mods/Official_Mods/*",
        "mods/Super_Mods/*",
        "mods/OT_Mods/*",
        "database/*"
      ],
      "matches": [
        "*://*.bestiaryarena.com/*",
        "*://bestiaryarena.com/*"
      ]
    }
  ]
}
