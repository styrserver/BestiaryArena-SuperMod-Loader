{
  "manifest_version": 2,
  "name": "BestiaryArena SuperMod Loader",
  "version": "4.5.3",
  "description": "SuperMod loader for Bestiary Arena - Advanced mod management system with enhanced features and custom mods.",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "background": {
    "scripts": [
      "content/extension-url.js",
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.bestiaryarena.com/*",
        "*://bestiaryarena.com/*"
      ],
      "exclude_matches": [
        "*://bestiaryarena.com/abilities*",
        "*://*.bestiaryarena.com/abilities*",
        "*://bestiaryarena.com/profile*",
        "*://*.bestiaryarena.com/profile*",
        "*://bestiaryarena.com/recolor*",
        "*://*.bestiaryarena.com/recolor*",
        "*://bestiaryarena.com/assets*",
        "*://*.bestiaryarena.com/assets*",
        "*://bestiaryarena.com/_next/*",
        "*://*.bestiaryarena.com/_next/*",
        "*://bestiaryarena.com/seasons*",
        "*://*.bestiaryarena.com/seasons*"
      ],
      "js": [
        "content/extension-url.js",
        "content/injector.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.bestiaryarena.com/*",
        "*://bestiaryarena.com/*"
      ],
      "exclude_matches": [
        "*://bestiaryarena.com/abilities*",
        "*://*.bestiaryarena.com/abilities*",
        "*://bestiaryarena.com/profile*",
        "*://*.bestiaryarena.com/profile*",
        "*://bestiaryarena.com/recolor*",
        "*://*.bestiaryarena.com/recolor*",
        "*://bestiaryarena.com/assets*",
        "*://*.bestiaryarena.com/assets*",
        "*://bestiaryarena.com/_next/*",
        "*://*.bestiaryarena.com/_next/*",
        "*://bestiaryarena.com/seasons*",
        "*://*.bestiaryarena.com/seasons*"
      ],
      "js": [
        "content/extension-url.js",
        "content/utility_injector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "*://*.bestiaryarena.com/*",
    "*://bestiaryarena.com/*",
    "*://bestiary-arena-ranking.vercel.app/*",
    "https://vip-list-messages-default-rtdb.europe-west1.firebasedatabase.app/*"
  ],
  "optional_permissions": [
    "*://*.gist.githubusercontent.com/*",
    "*://gist.githubusercontent.com/*",
    "*://*.raw.githubusercontent.com/*",
    "*://raw.githubusercontent.com/*"
  ],
  "web_accessible_resources": [
    "content/extension-url.js",
    "content/platform.js",
    "content/client.js",
    "content/local_mods.js",
    "content/mod-registry.js",
    "content/mod-coordination.mjs",
    "content/utility_injector.js",
    "content/ba-sandbox-utils.mjs",
    "content/custom-battles.js",
    "content/event-competition.js",
    "assets/icons/*",
    "assets/depot/*",
    "assets/js/*",
    "assets/fonts/*",
    "assets/locales/*",
    "assets/equipment/*",
    "assets/guild/*",
    "assets/quests/*",
    "assets/skills/*",
    "mods/*",
    "mods/Official_Mods/*",
    "mods/Super_Mods/*",
    "mods/OT_Mods/*",
    "database/*",
    "database/playereq-database.js",
    "database/equipment-database.js",
    "database/creature-database.js",
    "database/inventory-database.js",
    "database/maps-database.js",
    "database/equipment-lua-export.js",
    "database/creature-lua-export.js",
    "database/welcome.js"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bestiaryarena-supermodloader@private.local",
      "strict_min_version": "78.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": ["websiteContent", "technicalAndInteraction"]
      }
    },
    "gecko_android": {}
  },
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'; connect-src 'self' https://*.gist.githubusercontent.com https://gist.githubusercontent.com https://*.raw.githubusercontent.com https://raw.githubusercontent.com https://vip-list-messages-default-rtdb.europe-west1.firebasedatabase.app https://bestiary-arena-ranking.vercel.app"
}
